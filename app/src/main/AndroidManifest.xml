<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml — BJGU (Bro, Just Get Up) -->
<!-- Permissões necessárias para alarme fiável com ecrã completo -->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissão para usar o alarme exato (API 31+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Permissão para abrir Activity por cima do ecrã de bloqueio (API 27+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Permissão para manter o ecrã ligado durante o alarme -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Permissão para vibração -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Permissão para re-agendar alarmes após reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Permissão para ignorar otimização de bateria (pedida ao utilizador) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Permissão para foreground service (caso necessário) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Permissão para desenhar sobre outras apps (overlay) — necessaria para o alarme -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".BJGUApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BJGU"
        tools:targetApi="34">

        <!-- Activity principal — lista de alarmes -->
        <activity
            android:name=".ui.alarms.MainActivity"
            android:exported="true"
            android:launchMode="singleTop" />

        <!-- Activity de seleção de idioma (primeiro ecrã) -->
        <activity
            android:name=".ui.onboarding.LanguageActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Activity de onboarding (primeiro arranque) -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="true" />

        <!-- Activity de criação/edição de alarme -->
        <activity
            android:name=".ui.create.CreateAlarmActivity"
            android:exported="false"
            android:parentActivityName=".ui.alarms.MainActivity" />

        <!-- Activity de estatísticas -->
        <activity
            android:name=".ui.stats.StatsActivity"
            android:exported="false"
            android:parentActivityName=".ui.alarms.MainActivity" />

        <!-- Activity de settings (accountability) -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.alarms.MainActivity" />

        <!-- Activity de alarme a tocar — full-screen, por cima do bloqueio -->
        <activity
            android:name=".ui.ringing.AlarmRingingActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity="com.bjgu.app.alarmringing" />

        <!-- BroadcastReceiver — disparado pelo AlarmManager -->
        <receiver
            android:name=".alarm.AlarmReceiver"
            android:exported="false" />

        <!-- BroadcastReceiver — re-agendar alarmes após reboot -->
        <receiver
            android:name=".alarm.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider para partilhar QR codes -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
