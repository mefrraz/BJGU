<?xml version="1.0" encoding="utf-8"?>
<!-- activity_alarm_ringing.xml v3.1 — Redesign premium -->
<!-- Fundo gradiente pulsante (via código), desafio centrado, input minimalista -->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_alarm"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:keepScreenOn="true">

    <!-- Gradiente pulsante de fundo — overlay -->
    <View
        android:id="@+id/gradient_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_radial"
        android:alpha="0.15" />

    <!-- Banner de verificacao (escalada) -->
    <TextView
        android:id="@+id/text_escalated_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_escalated_banner"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/escalated_banner"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- PERGUNTA MATEMÁTICA — centro absoluto -->
    <TextView
        android:id="@+id/text_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 × 7 = ?"
        android:textColor="@color/text_primary"
        android:textSize="44sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        app:layout_constraintBottom_toTopOf="@id/input_answer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Input de resposta — só underline, sem caixa -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_answer_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:hint="@string/enter_answer"
        app:boxStrokeColor="@color/accent"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="2dp"
        app:boxStrokeErrorColor="@color/error"
        app:hintTextColor="@color/text_secondary"
        app:layout_constraintBottom_toTopOf="@id/buttons_row"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_question">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:inputType="numberSigned"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Feedback de erro/acerto -->
    <TextView
        android:id="@+id/text_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/input_answer_layout" />

    <!-- Botão Verificar -->
    <Button
        android:id="@+id/btn_check"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/accent"
        android:text="@string/check_answer"
        android:textColor="@color/background"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.03"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@id/btn_stop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Botão DESLIGAR — ESCONDIDO até resposta certa -->
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="48dp"
        android:alpha="0.4"
        android:backgroundTint="@color/success"
        android:clickable="false"
        android:enabled="false"
        android:text="@string/stop_alarm"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.05"
        app:cornerRadius="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- SNOOZE — discreto, canto superior direito -->
    <TextView
        android:id="@+id/btn_snooze"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="20dp"
        android:padding="12dp"
        android:text="@string/snooze_5min"
        android:textColor="@color/text_disabled"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Secções escondidas por default -->
    <LinearLayout
        android:id="@+id/shake_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_shake_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shake_title"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/text_shake_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="0 / 10"
            android:textColor="@color/text_primary"
            android:textSize="56sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/shake_instruction"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/qr_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_qr_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/qr_scan_title"
            android:textColor="@color/accent"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light" />

        <Button
            android:id="@+id/btn_scan_qr"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/accent"
            android:text="@string/scan_qr_code"
            android:textColor="@color/background"
            app:cornerRadius="28dp" />

        <Button
            android:id="@+id/btn_qr_fallback"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/no_qr_code"
            android:textColor="@color/text_disabled"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Wrapper para card_challenge e buttons_row (compatibilidade) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_challenge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_escalated_banner" />

    <LinearLayout
        android:id="@+id/buttons_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
