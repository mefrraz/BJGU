<?xml version="1.0" encoding="utf-8"?>
<!-- activity_create_alarm.xml v3.1 — Criar alarme premium -->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- RELÓGIO DIGITAL — hora grande no topo -->
        <TextView
            android:id="@+id/text_clock_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:text="07:30"
            android:textColor="@color/text_primary"
            android:textSize="48sp" />

        <!-- Pickers lado a lado: horas e minutos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <NumberPicker
                android:id="@+id/picker_hour"
                android:layout_width="100dp"
                android:layout_height="180dp"
                android:theme="@style/NumberPickerStyle" />

            <TextView
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:text=":"
                android:textColor="@color/text_secondary"
                android:textSize="36sp" />

            <NumberPicker
                android:id="@+id/picker_minute"
                android:layout_width="100dp"
                android:layout_height="180dp"
                android:theme="@style/NumberPickerStyle" />
        </LinearLayout>

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:background="@color/surface_high" />

        <!-- DIAS — círculos clicáveis -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif"
            android:text="@string/days_of_week"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:chipSpacing="6dp"
            app:singleSelection="false" />

        <!-- SOM -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif"
            android:text="@string/alarm_sound"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <Button
            android:id="@+id/btn_select_sound"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="@string/select_sound"
            android:textColor="@color/text_primary"
            app:cornerRadius="14dp" />

        <TextView
            android:id="@+id/text_sound_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="@string/system_default"
            android:textColor="@color/text_disabled"
            android:textSize="12sp" />

        <!-- TIPO DE DESAFIO — 3 cards -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif"
            android:text="@string/challenge_type_label"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:id="@+id/challenge_cards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <!-- Card Matemática -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_math"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧮"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/challenge_math"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Shake -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_shake"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/surface_high"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📳"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/challenge_shake"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card QR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_qr"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/surface_high"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/challenge_qr"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Opções condicionais — Matemática (dificuldade) -->
        <LinearLayout
            android:id="@+id/options_math"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="@string/difficulty"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_difficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:checkedButton="@+id/btn_easy"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:cornerRadius="44dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_easy"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/easy"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_medium"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/medium"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_hard"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/hard"
                    android:textSize="13sp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- Opções condicionais — QR Code -->
        <LinearLayout
            android:id="@+id/options_qr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/img_qr_preview"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_share_qr"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/share_qr"
                android:textColor="@color/text_primary"
                android:visibility="gone"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <!-- GUARDAR -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/accent"
            android:fontFamily="sans-serif"
            android:text="@string/save"
            android:textColor="@color/background"
            android:textSize="16sp"
            android:letterSpacing="0.03"
            app:cornerRadius="28dp" />
    </LinearLayout>
</ScrollView>
