<?xml version="1.0" encoding="utf-8"?>
<!-- Cores BJGU v3.1 — Tema escuro premium -->
<resources>
    <!-- Fundo principal (quase preto, não o cinzento Material default) -->
    <color name="background">#FF0F0F12</color>

    <!-- Superfície de cards (levemente elevada) -->
    <color name="surface">#FF1A1A1F</color>

    <!-- Superfície de cards em hover/press -->
    <color name="surface_high">#FF24242B</color>

    <!-- Cor de destaque — Laranja coral vibrante -->
    <color name="accent">#FFF0997B</color>

    <!-- Variante mais escura do destaque (para backgrounds) -->
    <color name="accent_dark">#FFC0785E</color>

    <!-- Verde sucesso (para respostas certas) -->
    <color name="success">#FF5DCAA5</color>

    <!-- Vermelho erro (suave, não agressivo) -->
    <color name="error">#FFE0887B</color>

    <!-- Texto principal (branco puro) -->
    <color name="text_primary">#FFFFFFFF</color>

    <!-- Texto secundário (cinza quente) -->
    <color name="text_secondary">#FF8E8E98</color>

    <!-- Texto desativado / inativo -->
    <color name="text_disabled">#FF4A4A52</color>

    <!-- Switch / toggle track inativo -->
    <color name="track_inactive">#FF3A3A40</color>

    <!-- Switch / toggle track ativo = destaque -->
    <color name="track_active">@color/accent</color>
</resources>
